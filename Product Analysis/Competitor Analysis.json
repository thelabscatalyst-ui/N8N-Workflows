    {
      "parameters": {
        "jsCode": "// ── MARKDOWN CLEANER — trim tail junk, preserve product content ─────────────\nconst md = $input.item.json.markdown || '';\nlet brand = '';\nlet sheetTab = '';\n\ntry {\n  brand = $('Map Brand Fields').item.json.brand || '';\n  sheetTab = $('Map Brand Fields').item.json.sheet_tab || '';\n} catch (error) {\n  console.error('Error accessing Map Brand Fields:', error);\n}\n\n// Step 1: Split into lines for targeted removal\nlet lines = md.split('\\n');\n\n// Step 2: Detect where \"junk zone\" starts — common footer/noise signals\nconst JUNK_SIGNALS = [\n  /^#+\\s*(footer|legal|privacy|terms|cookie|newsletter|subscribe|follow us|social|contact us|copyright|sitemap|faq|help center|returns|shipping policy|about us|careers|press)/i,\n  /^#+\\s*(you may also (like|love)|related products|recently viewed|recommended|trending|bestsellers outside)/i,\n  /^\\*{0,2}(©|copyright|\\(c\\))\\s*\\d{4}/i,\n  /^(all rights reserved|privacy policy|terms of (use|service)|refund policy)/i,\n];\n\nlet cutLine = lines.length; // default: keep everything\n\nfor (let i = 0; i < lines.length; i++) {\n  const line = lines[i].trim();\n  if (JUNK_SIGNALS.some(rx => rx.test(line))) {\n    // Only cut if we're past the first 30% of the document\n    // (avoids cutting real content that happens to match early)\n    if (i > lines.length * 0.3) {\n      cutLine = i;\n      break;\n    }\n  }\n}\n\nlines = lines.slice(0, cutLine);\n\n// Step 3: Remove nav link dumps — lines that are just a pile of [text](url) with no product info\n// A \"link dump\" = 5+ consecutive lines that are only markdown links, no prices, no descriptions\nlet cleaned = [];\nlet linkRunCount = 0;\nconst LINK_ONLY_LINE = /^\\s*[-*]?\\s*\\[.+?\\]\\(.+?\\)\\s*$/;\nconst HAS_PRICE = /₹|Rs\\.?|INR|\\d{3,}/;\n\nfor (const line of lines) {\n  if (LINK_ONLY_LINE.test(line) && !HAS_PRICE.test(line)) {\n    linkRunCount++;\n    if (linkRunCount <= 4) cleaned.push(line); // keep first few, drop the rest of a long run\n  } else {\n    linkRunCount = 0;\n    cleaned.push(line);\n  }\n}\n\n// Step 4: Collapse 3+ consecutive blank lines into 1\nlet result = cleaned.join('\\n').replace(/\\n{3,}/g, '\\n\\n').trim();\n\n// Step 5: Safety net — only if still huge (>40K chars), hard cut at last product-looking line\nif (result.length > 40000) {\n  const PRICE_LINE = /₹|Rs\\.?|INR|\\d{3,}/;\n  const resultLines = result.split('\\n');\n  let lastProductLine = 15000; // fallback\n  for (let i = resultLines.length - 1; i >= 0; i--) {\n    if (PRICE_LINE.test(resultLines[i])) {\n      lastProductLine = i + 5; // keep a few lines of context after last price\n      break;\n    }\n  }\n  result = resultLines.slice(0, lastProductLine).join('\\n').trim();\n}\n\nreturn {\n  json: {\n    brand,\n    sheet_tab: sheetTab,\n    cleaned_markdown: result,\n    original_chars: md.length,\n    cleaned_chars: result.length,\n    reduction_pct: Math.round((1 - result.length / md.length) * 100)\n  }\n};"
      },
      "id": "5fd2b4d1-9151-4bc8-bdac-95e70ca517e2",
