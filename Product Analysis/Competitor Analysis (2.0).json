    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $input.item.json;\nconst s = d.summary;\nlet h = '<h2>Competitor Intelligence: ' + d.brand + '</h2>';\nh += '<p>Run: ' + new Date().toLocaleDateString('en-IN') + '</p>';\nh += '<p>New: <b>' + s.new_count + '</b> | Changed: <b>' + s.updated_count + '</b> | Removed: <b>' + s.removed_count + '</b></p>';\nif (d.new_products?.length) { h += '<h3 style=\"color:#2e7d32\">New Products</h3><ul>'; for(const p of d.new_products) h += '<li><b>'+p.name+'</b> Rs.'+(p.price||'N/A')+' ['+p.category+']</li>'; h += '</ul>'; }\nif (d.updated_products?.length) { h += '<h3 style=\"color:#e65100\">Price Changes</h3><ul>'; for(const p of d.updated_products) { const up=parseFloat(p.price_delta)>0; h += '<li><b>'+p.name+'</b>: Rs.'+p.old_price+' to Rs.'+p.price+' ('+(up?'+':'')+p.price_delta+')</li>'; } h += '</ul>'; }\nif (d.removed_products?.length) { h += '<h3 style=\"color:#888\">Removed</h3><ul>'; for(const n of d.removed_products) h += '<li>'+n+'</li>'; h += '</ul>'; }\nh += '<p><a href=\"https://docs.google.com/spreadsheets/d/1FDTqrcWRbU5v35FirKleCYwbC3W2E6acQ9lx0wCTeUA\">Open Catalogue</a></p>';\nreturn [{ json: { brand: d.brand, html: h, subject: 'Competitor Alert: '+d.brand+' ('+s.new_count+' new, '+s.updated_count+' changed)' } }];"
      },
