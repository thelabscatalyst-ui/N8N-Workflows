    {
      "parameters": {
        "jsCode": "const all = $input.all();\nconst first = all[0].json;\nconst incoming = first.products || [];\nconst brand = first.brand;\nconst sheetTab = first.sheet_tab;\nconst existing = all.slice(1).map(i=>i.json);\nconst map = {};\nfor (const r of existing) { const k=(r.name||'').toLowerCase().trim(); if(k) map[k]=r; }\nconst newP=[], updatedP=[], unchanged=[];\nfor (const p of incoming) {\n  const k=(p.name||'').toLowerCase().trim();\n  if (!k) continue;\n  const ex = map[k];\n  if (!ex) { newP.push({...p, change_type:'NEW'}); continue; }\n  const changed = String(ex.price)!==String(p.price)||(ex.description||'').trim()!==(p.description||'').trim()||(ex.category||'').trim()!==(p.category||'').trim()||(ex.tags||'').trim()!==(p.tags||'').trim();\n  if (changed) updatedP.push({...p, old_price:ex.price, change_type:'UPDATED', price_delta: (p.price-parseFloat(ex.price||0)).toFixed(0)});\n  else unchanged.push(p.name);\n}\nconst inNames = new Set(incoming.map(p=>(p.name||'').toLowerCase().trim()));\nconst removed = existing.filter(r=>r.name&&!inNames.has((r.name||'').toLowerCase().trim())).map(r=>r.name);\nreturn [{ json: { brand, sheet_tab: sheetTab, has_changes: newP.length>0||updatedP.length>0||removed.length>0, new_products: newP, updated_products: updatedP, removed_products: removed, unchanged_count: unchanged.length, summary: { new_count: newP.length, updated_count: updatedP.length, removed_count: removed.length } } }];"
      },
      "id": "0afc7032-c9fe-4783-a41d-9bfc4adbedca",
      "name": "Detect Changes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        -16
      ]
    }
  ],
