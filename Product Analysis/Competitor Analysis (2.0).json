              "role": "system",
              "content": "Extract ALL products from the text. Return ONLY valid JSON no markdown.\nFormat: {\"products\":[{\"name\":\"string\",\"description\":\"string\",\"price\":0,\"category\":\"string\",\"tags\":[]}]}\nRules: price=number or null, tags=array, no hallucination."
            },
