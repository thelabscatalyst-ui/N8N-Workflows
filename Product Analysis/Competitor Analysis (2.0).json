    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const brand = $('Striping').item.json.brand;\nconst sheetTab = $('Striping').item.json.sheet_tab;\nlet raw = $input.item.json.message?.content || '';\ntry { raw = raw.replace(/^```json\\n?/,'').replace(/\\n?```$/,'').trim(); } catch(e){}\nlet parsed;\ntry { parsed = JSON.parse(raw); } catch(e) { return [{ json: { brand, sheet_tab: sheetTab, products: [] } }]; }\nconst today = new Date().toISOString().split('T')[0];\nconst products = (parsed.products||[]).map(p=>({ brand, sheet_tab: sheetTab, name:(p.name||'').trim(), description:(p.description||'').trim(), price: typeof p.price==='number'?p.price:null, category:(p.category||'').trim(), tags: Array.isArray(p.tags)?p.tags.join(', '):(p.tags||''), scraped_at: today }));\nreturn [{ json: { brand, sheet_tab: sheetTab, products } }];"
      },
